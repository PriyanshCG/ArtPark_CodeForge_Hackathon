# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
SESSION_SECRET=artpark_session_secret

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/adaptive-onboarding

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=super_secret_for_development

# ── AI Providers ──────────────────────────────────────────────────────────────
# Set provider to 'groq', 'gemini', or 'openai'
LLM_PROVIDER=gemini 
EMBEDDING_PROVIDER=gemini

GROQ_API_KEY=dummy_groq_key
GEMINI_API_KEY=dummy_gemini_key
OPENAI_API_KEY=dummy_openai_key

# ── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── File Uploads ──────────────────────────────────────────────────────────────
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads
